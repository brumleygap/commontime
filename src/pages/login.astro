---
import BaseLayout from "../layouts/BaseLayout.astro";
import { actions } from "astro:actions";

if (Astro.locals.user) {
  return Astro.redirect("/");
}

const result = await Astro.getActionResult(actions.sendMagicLink);
const errorParam = Astro.url.searchParams.get("error");
const errorMessages: Record<string, string> = {
  invalid_token: "That login link is invalid or has expired. Please request a new one.",
  missing_token: "No login token was found. Please request a new link.",
};
---

<BaseLayout title="Log in — CommonTime">
  <section class="mx-auto max-w-md px-4 py-16">
    <h1 class="text-2xl font-bold text-slate-900">Log in</h1>

    {result?.data?.ok ? (
      <div class="mt-6 rounded-md border border-emerald-300 bg-emerald-50 p-4 text-emerald-900">
        <p class="font-semibold">Check your email</p>
        <p class="mt-1 text-sm">We sent a login link. It expires in 15 minutes.</p>
      </div>
    ) : (
      <>
        {(errorParam && errorMessages[errorParam]) && (
          <div class="mt-6 rounded-md border border-red-300 bg-red-50 p-4 text-red-800">
            <p>{errorMessages[errorParam]}</p>
          </div>
        )}
        {result?.error && (
          <div class="mt-6 rounded-md border border-red-300 bg-red-50 p-4 text-red-800">
            <p>{result.error.message}</p>
          </div>
        )}

        <form method="POST" action={actions.sendMagicLink} class="mt-8 space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700">
              Email address
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autofocus
              placeholder="you@example.com"
              class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-red-500 focus:ring-red-500"
            />
          </div>
          <button
            type="submit"
            class="w-full rounded-md bg-red-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-red-700"
          >
            Send magic link
          </button>
        </form>
      </>
    )}
  </section>
</BaseLayout>
