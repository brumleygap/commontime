---
import BaseLayout from "../layouts/BaseLayout.astro";
import { actions } from "astro:actions";

if (Astro.locals.user) {
  return Astro.redirect("/");
}

const result = await Astro.getActionResult(actions.sendMagicLink);
const errorParam = Astro.url.searchParams.get("error");
const errorMessages: Record<string, string> = {
  invalid_token: "That login link is invalid or has expired. Please request a new one.",
  missing_token: "No login token was found. Please request a new link.",
};
---

<BaseLayout title="Log in">
  <section class="relative overflow-hidden" style="min-height: calc(100vh - 120px);">
    <div class="staff-bg absolute inset-0" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-md px-4 py-16">
      <p class="ct-eyebrow mb-2">Welcome back</p>
      <h1 class="login-title">Log <em>in</em></h1>

      {result?.data?.ok ? (
        <div class="login-card">
          <div class="check-banner">
            <strong>Check your email</strong>
            <span>We sent a magic link. It expires in 15 minutes.</span>
          </div>
        </div>
      ) : (
        <>
          {errorParam && errorMessages[errorParam] && (
            <div class="error-banner">{errorMessages[errorParam]}</div>
          )}

          <!-- Passkey error injected by client JS -->
          <div id="passkey-error" class="error-banner" style="display:none;"></div>

          <div class="login-card">
            <!-- Primary: discoverable passkey sign-in (no email needed) -->
            <button id="passkey-btn" type="button" class="ct-btn passkey-primary-btn">
              Sign in with a passkey
            </button>

            <div class="divider"><span>or use your email</span></div>

            <!-- Secondary: email for magic link or passkey registration -->
            <div class="field-group">
              <label for="email" class="field-label">Email address</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email webauthn"
                placeholder="you@example.com"
                class="field-input"
              />
            </div>

            {result?.error && (
              <div class="error-banner" style="margin-bottom:16px;">{result.error.message}</div>
            )}

            <button id="register-passkey-btn" type="button" class="ct-btn" style="width:100%;justify-content:center;">
              Create a passkey
            </button>

            <form id="email-form" method="POST" action={actions.sendMagicLink} style="margin-top:12px;">
              <input type="hidden" id="email-hidden" name="email" value="" />
              <button type="submit" class="magic-link-btn" style="width:100%;text-align:center;">
                Email me a link instead
              </button>
            </form>
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  import {
    startRegistration,
    startAuthentication,
    browserSupportsWebAuthn,
  } from "@simplewebauthn/browser";

  const passkeyBtn = document.getElementById("passkey-btn") as HTMLButtonElement | null;
  const registerBtn = document.getElementById("register-passkey-btn") as HTMLButtonElement | null;
  const emailInput = document.getElementById("email") as HTMLInputElement | null;
  const emailHidden = document.getElementById("email-hidden") as HTMLInputElement | null;
  const emailForm = document.getElementById("email-form") as HTMLFormElement | null;
  const errorBox = document.getElementById("passkey-error") as HTMLDivElement | null;

  // Sync visible email field into the hidden form input before submission
  emailForm?.addEventListener("submit", (e) => {
    const email = emailInput?.value.trim() ?? "";
    if (!email) {
      e.preventDefault();
      showError("Enter your email address first.");
      emailInput?.focus();
      return;
    }
    if (emailHidden) emailHidden.value = email;
  });

  function showError(msg: string) {
    if (!errorBox) return;
    errorBox.textContent = msg;
    errorBox.style.display = "block";
    errorBox.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function clearError() {
    if (!errorBox) return;
    errorBox.style.display = "none";
    errorBox.textContent = "";
  }

  // Fetch and parse JSON with a 20s timeout; throws a diagnostic error on non-JSON or timeout
  async function fetchJSON(input: RequestInfo, init?: RequestInit): Promise<{ status: number; data: any }> {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 20_000);
    try {
      const res = await fetch(input, { ...init, signal: controller.signal });
      const text = await res.text();
      let data: any;
      try {
        data = JSON.parse(text);
      } catch {
        throw new Error(`HTTP ${res.status} — server returned non-JSON: ${text.slice(0, 120)}`);
      }
      return { status: res.status, data };
    } catch (err: any) {
      if (err?.name === "AbortError") throw new Error("Request timed out after 20s — server may be overloaded");
      throw err;
    } finally {
      clearTimeout(timer);
    }
  }

  // Hide passkey buttons on unsupported browsers
  if (!browserSupportsWebAuthn()) {
    if (passkeyBtn) passkeyBtn.style.display = "none";
    const divider = document.querySelector(".divider") as HTMLElement | null;
    if (divider) divider.style.display = "none";
    if (registerBtn) registerBtn.style.display = "none";
  }

  // Discoverable sign-in — no email required
  passkeyBtn?.addEventListener("click", async () => {
    clearError();
    passkeyBtn.disabled = true;
    passkeyBtn.textContent = "Waiting for biometric…";

    try {
      const { status: s1, data: options } = await fetchJSON("/auth/passkey-authenticate");
      if (s1 !== 200) throw new Error(options.error ?? `Auth options failed (${s1})`);

      const assertion = await startAuthentication({ optionsJSON: options });

      const { status: s2, data } = await fetchJSON("/auth/passkey-authenticate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(assertion),
      });
      if (!data.ok) throw new Error(data.error ?? `Sign-in failed (${s2})`);
      passkeyBtn.textContent = "Signed in! Redirecting…";
      window.location.href = "/";
    } catch (err: any) {
      // NotAllowedError = user cancelled — not an app error
      if (err?.name !== "NotAllowedError") {
        showError(err?.message ?? "Something went wrong. Try emailing a link instead.");
      }
      passkeyBtn.disabled = false;
      passkeyBtn.textContent = "Sign in with a passkey";
    }
  });

  // Register a new passkey tied to an email
  registerBtn?.addEventListener("click", async () => {
    const email = emailInput?.value.trim();
    if (!email) {
      emailInput?.focus();
      showError("Enter your email address first.");
      return;
    }
    clearError();
    registerBtn.disabled = true;
    registerBtn.textContent = "Waiting for biometric…";

    try {
      const { status: s1, data: optionsData } = await fetchJSON(`/auth/passkey-register?email=${encodeURIComponent(email)}`);
      if (s1 !== 200) throw new Error(optionsData.error ?? `Register options failed (${s1})`);
      const { options, userId } = optionsData;

      const attestation = await startRegistration({ optionsJSON: options });

      const { status: s2, data } = await fetchJSON("/auth/passkey-register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ response: attestation, userId }),
      });
      if (!data.ok) throw new Error(data.error ?? `Registration failed (${s2})`);
      registerBtn.textContent = "Passkey created! Redirecting…";
      window.location.href = "/";
    } catch (err: any) {
      if (err?.name !== "NotAllowedError") {
        showError(err?.message ?? "Something went wrong. Try emailing a link instead.");
      }
      registerBtn.disabled = false;
      registerBtn.textContent = "Create a passkey";
    }
  });
</script>

<style>
  .login-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 8vw, 56px);
    font-weight: 900;
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: 28px;
  }

  .login-title em {
    color: var(--red);
    font-style: italic;
  }

  .login-card {
    background: var(--white);
    border: 1px solid var(--staff);
    border-top: 3px solid var(--red);
    padding: 28px 24px;
  }

  .passkey-primary-btn {
    width: 100%;
    justify-content: center;
    font-size: 15px;
    padding: 14px 20px;
    min-height: 52px;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--staff);
  }

  .check-banner {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 4px 0;
  }

  .check-banner strong {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--green);
  }

  .check-banner span {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--muted);
  }

  .error-banner {
    margin-bottom: 16px;
    padding: 14px 18px;
    background: var(--busy-bg);
    border-left: 3px solid var(--red);
    font-family: 'Libre Baskerville', serif;
    font-size: 17px;
    color: var(--ink);
  }

  .field-group {
    margin-bottom: 20px;
  }

  .field-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .field-input {
    width: 100%;
    border: none;
    border-bottom: 2px solid var(--ink);
    background: transparent;
    font-family: 'Libre Baskerville', serif;
    font-size: 18px;
    color: var(--ink);
    padding: 8px 0 10px;
    outline: none;
    transition: border-color 0.2s;
  }

  .field-input:focus {
    border-color: var(--red);
  }

  .field-input::placeholder {
    color: var(--placeholder);
  }

  .email-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .magic-link-btn {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px 0;
    text-decoration: underline;
    text-underline-offset: 3px;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .magic-link-btn:hover {
    color: var(--ink);
  }
</style>
