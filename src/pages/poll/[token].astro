---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { actions } from "astro:actions";

const { token } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const voteResult = await Astro.getActionResult(actions.submitVoteDebug);
const voteError = voteResult?.error;
const voteSuccess = voteResult?.data && (voteResult.data as any).ok === true;

function formatOptionDate(dt: string) {
  const d = new Date(dt);
  return d.toLocaleString("en-US", {
    weekday: "short", month: "2-digit", day: "2-digit",
    year: "2-digit", hour: "numeric", minute: "2-digit", hour12: true,
  });
}

function formatColDate(dt: string) {
  const d = new Date(dt);
  return {
    date: d.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" }),
    time: d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit", hour12: true }),
  };
}

function bgColor(available: number, total: number): string {
  if (total === 0 || available === 0) return "#ffffff";
  const ratio = available / total;
  const lightness = Math.round(90 - ratio * 62);
  return `hsl(142, 71%, ${lightness}%)`;
}

function fgColor(available: number, total: number): string {
  if (total === 0 || available === 0) return "#94a3b8";
  const ratio = available / total;
  return ratio >= 0.6 ? "#ffffff" : "#166534";
}

const poll = await db
  .prepare(`SELECT id, token, title, description, timezone, created_at FROM polls WHERE token = ?`)
  .bind(token)
  .first<{ id: number; token: string; title: string; description: string | null; timezone: string; created_at: string }>();

if (!poll) return new Response("Poll not found", { status: 404 });

const options = (await db
  .prepare(`SELECT id, option_datetime FROM poll_options WHERE poll_id = ? ORDER BY option_datetime ASC`)
  .bind(poll.id)
  .all<{ id: number; option_datetime: string }>()).results;

const participants = (await db
  .prepare(`SELECT id, name FROM participants WHERE poll_id = ? ORDER BY created_at ASC`)
  .bind(poll.id)
  .all<{ id: number; name: string | null }>()).results;

const allVotes = (await db
  .prepare(`
    SELECT v.participant_id, v.option_id, v.availability
    FROM votes v
    JOIN participants p ON p.id = v.participant_id
    WHERE p.poll_id = ?
  `)
  .bind(poll.id)
  .all<{ participant_id: number; option_id: number; availability: number }>()).results;

// participantId → optionId → available
const voteMap = new Map<number, Map<number, boolean>>();
for (const v of allVotes) {
  if (!voteMap.has(v.participant_id)) voteMap.set(v.participant_id, new Map());
  voteMap.get(v.participant_id)!.set(v.option_id, v.availability === 1);
}

const optionStats = options.map(opt => {
  const names: string[] = [];
  for (const p of participants) {
    if (voteMap.get(p.id)?.get(opt.id)) names.push(p.name ?? "Anonymous");
  }
  return { ...opt, availableCount: names.length, availableNames: names };
});
---

<BaseLayout title={poll.title}>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="text-2xl font-bold text-slate-900">{poll.title}</h1>
    {poll.description && <p class="mt-2 text-slate-600">{poll.description}</p>}

    <!-- Voting form -->
    <div class="mt-6 rounded-md border bg-white p-5">
      <h2 class="text-sm font-semibold text-slate-800">Add your availability</h2>
      <p class="mt-1 text-sm text-slate-500">Check every time that works for you.</p>

      {voteError && (
        <div class="mt-4 rounded-md border border-red-300 bg-red-50 p-4 text-red-900">
          <p class="font-semibold">We couldn't save your response.</p>
          {voteError.message && (
            <p class="mt-1 text-sm">{voteError.message}</p>
          )}
          <details class="mt-2 text-xs">
            <summary class="cursor-pointer underline">Technical details</summary>
            <pre class="mt-1 whitespace-pre-wrap">{JSON.stringify(voteError, null, 2)}</pre>
          </details>
        </div>
      )}

      {voteSuccess && (
        <div class="mt-4 rounded-md border border-emerald-300 bg-emerald-50 p-4 text-emerald-900">
          <p class="font-semibold">Your response has been saved.</p>
          <p class="mt-1 text-sm">Scroll down to see the updated availability.</p>
        </div>
      )}

      <form method="POST" action={actions.submitVoteDebug} class="mt-4 space-y-3">
        <input type="hidden" name="token" value={token} />
        <label class="block text-sm font-medium text-slate-700">
          Your name (optional)
          <input type="text" name="name"
            value={Astro.locals.user?.email ?? ""}
            placeholder="Your name or email"
            class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-red-500 focus:ring-red-500" />
        </label>
        {options.map(opt => (
          <label class="flex items-center gap-3">
            <input type="checkbox" name="optionIds" value={opt.id} class="h-4 w-4 rounded" />
            <span class="text-slate-800 text-sm">{formatOptionDate(opt.option_datetime)}</span>
          </label>
        ))}
        <div class="mt-4 flex justify-end">
          <button type="submit"
            class="rounded-md bg-red-600 px-5 py-2 text-sm font-semibold text-white hover:bg-red-700">
            {voteSuccess ? "Update my response" : "Save my response"}
          </button>
        </div>
      </form>
    </div>

    <!-- Availability grid -->
    <div class="mt-10">
      <h2 class="text-lg font-semibold text-slate-900">Availability</h2>

      {participants.length === 0 ? (
        <p class="mt-3 text-sm text-slate-500">No responses yet. Be the first!</p>
      ) : (
        <div class="mt-4 overflow-x-auto rounded-md border border-slate-200 bg-white">
          <table class="min-w-full border-separate border-spacing-0 text-sm">
            <thead>
              <tr>
                <!-- Name column header -->
                <th class="sticky left-0 z-10 bg-white px-4 py-3 text-left font-medium text-slate-500 border-b border-r border-slate-200 min-w-[140px]">
                  Participant
                </th>

                {optionStats.map(opt => {
                  const { date, time } = formatColDate(opt.option_datetime);
                  const bg = bgColor(opt.availableCount, participants.length);
                  const fg = fgColor(opt.availableCount, participants.length);
                  return (
                    <th class="border-b border-r border-slate-200 p-0 min-w-[110px] last:border-r-0 cursor-default"
                      data-names={JSON.stringify(opt.availableNames)}
                      data-count={`${opt.availableCount}/${participants.length}`}>
                      <div class="flex flex-col items-center justify-center gap-0.5 px-3 py-3"
                        style={`background-color: ${bg}; color: ${fg};`}>
                        <span class="font-semibold text-xs leading-tight">{date}</span>
                        <span class="text-xs opacity-90">{time}</span>
                        <span class="mt-1 text-xs font-bold">
                          {opt.availableCount}/{participants.length}
                        </span>
                      </div>
                    </th>
                  );
                })}
              </tr>
            </thead>

            <tbody>
              {participants.map((p, i) => (
                <tr class={i % 2 === 1 ? "bg-slate-50" : "bg-white"}>
                  <td class="sticky left-0 z-10 border-r border-slate-200 px-4 py-2.5 font-medium text-slate-700"
                    style={i % 2 === 1 ? "background: #f8fafc" : "background: #fff"}>
                    {p.name ?? <span class="italic text-slate-400">Anonymous</span>}
                  </td>

                  {options.map(opt => {
                    const available = voteMap.get(p.id)?.get(opt.id) ?? false;
                    return (
                      <td class="border-r border-slate-100 px-4 py-2.5 text-center last:border-r-0">
                        {available
                          ? <span class="text-emerald-600 font-bold text-base">✓</span>
                          : <span class="text-slate-200 text-base">–</span>
                        }
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const tip = document.createElement("div");
  tip.style.cssText = "position:fixed;z-index:9999;display:none;pointer-events:none;background:#1e293b;color:#fff;border-radius:6px;padding:8px 12px;font-size:12px;line-height:1.5;white-space:nowrap;box-shadow:0 4px 12px rgba(0,0,0,.3)";
  document.body.appendChild(tip);

  function place(e: MouseEvent) {
    const x = e.clientX;
    const y = e.clientY;
    tip.style.left = (x - tip.offsetWidth / 2) + "px";
    tip.style.top  = (y - tip.offsetHeight - 12) + "px";
  }

  document.querySelectorAll<HTMLElement>("th[data-names]").forEach(th => {
    th.addEventListener("mouseenter", (e) => {
      const names: string[] = JSON.parse(th.dataset.names ?? "[]");
      const count = th.dataset.count ?? "";
      tip.innerHTML = names.length
        ? `<span style="color:#94a3b8;font-weight:600">Available (${count})</span><br>${names.map(n => `<span>${n}</span>`).join("<br>")}`
        : `<span style="color:#94a3b8">No one available</span>`;
      tip.style.display = "block";
      place(e as MouseEvent);
    });
    th.addEventListener("mousemove", (e) => place(e as MouseEvent));
    th.addEventListener("mouseleave", () => { tip.style.display = "none"; });
  });
</script>
