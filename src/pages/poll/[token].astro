<script>
  // vote state: optionId (string) → availability (0|1|2|-1 = unset)
  const state: Record<string, number> = {};

  // Initialise from server-rendered data attributes
  document.querySelectorAll<HTMLElement>(".time-row").forEach((row) => {
    const id = row.dataset.optionId!;
    const init = parseInt(row.dataset.init ?? "-1", 10);
    state[id] = init >= 0 ? init : -1;

    // Highlight the pre-existing vote button
    if (init >= 0) {
      row.querySelector<HTMLButtonElement>(`.vibe-btn[data-vibe="${init}"]`)?.classList.add("active");
      applyBullet(row, init);
    }

    // Wire up vibe buttons
    row.querySelectorAll<HTMLButtonElement>(".vibe-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const vibe = parseInt(btn.dataset.vibe!, 10);
        state[id] = vibe;
        // Toggle active class
        row.querySelectorAll(".vibe-btn").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        applyBullet(row, vibe);
      });
    });
  });

  function applyBullet(row: HTMLElement, vibe: number) {
    const bullet = row.querySelector<HTMLElement>("[data-bullet]");
    if (!bullet) return;
    if (vibe === 1) bullet.style.background = "var(--yes)";
    else if (vibe === 2) bullet.style.background = "var(--maybe)";
    else if (vibe === 0) bullet.style.background = "var(--red)";
    else bullet.style.background = "var(--bullet)";
  }

  document.getElementById("vote-form")?.addEventListener("submit", (e) => {
    const voteData = Object.entries(state)
      .filter(([, av]) => av >= 0)
      .map(([optionId, availability]) => ({ optionId: parseInt(optionId, 10), availability }));

    if (voteData.length === 0) {
      // Default all unset options to "busy" (0) so the submission is not empty
      const allIds = Array.from(document.querySelectorAll<HTMLElement>(".time-row"))
        .map((r) => parseInt(r.dataset.optionId!, 10));
      const fallback = allIds.map((id) => ({ optionId: id, availability: 0 }));
      (document.getElementById("vote-data") as HTMLInputElement).value = JSON.stringify(fallback);
    } else {
      // Fill in any unset options as busy
      const allIds = Array.from(document.querySelectorAll<HTMLElement>(".time-row"))
        .map((r) => parseInt(r.dataset.optionId!, 10));
      const full = allIds.map((id) => ({
        optionId: id,
        availability: state[String(id)] >= 0 ? state[String(id)] : 0,
      }));
      (document.getElementById("vote-data") as HTMLInputElement).value = JSON.stringify(full);
    }
  });
</script>
