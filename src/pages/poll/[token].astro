---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { actions } from "astro:actions";
import { env } from "cloudflare:workers";

const { token } = Astro.params;
const db = env.DB;

const voteResult = await Astro.getActionResult(actions.submitVote);
const voteError = voteResult?.error;
const voteSuccess = voteResult?.data?.ok === true;

const lockResult = await Astro.getActionResult(actions.lockPoll);
const lockError = lockResult?.error;

const inviteResult = await Astro.getActionResult(actions.inviteParticipants);
const inviteError = inviteResult?.error;

// ── Data loading ──────────────────────────────────────────────────────────────

const poll = await db
  .prepare(
    `SELECT id, token, title, description, timezone, creator_id, created_at, chosen_option_id
     FROM polls WHERE token = ?`
  )
  .bind(token)
  .first<{
    id: number;
    token: string;
    title: string;
    description: string | null;
    timezone: string;
    creator_id: number | null;
    created_at: string;
    chosen_option_id: number | null;
  }>();

if (!poll) return new Response("Poll not found", { status: 404 });

// Track this poll in the browser so the home page can surface it,
// even if the visitor has never voted (e.g. they were invited and haven't responded yet).
const prevTokens = (Astro.cookies.get("recent_polls")?.value ?? "").split(",").filter(Boolean);
if (!prevTokens.includes(poll.token)) prevTokens.unshift(poll.token);
Astro.cookies.set("recent_polls", prevTokens.slice(0, 10).join(","), {
  path: "/",
  maxAge: 60 * 60 * 24 * 90,
  sameSite: "lax",
  secure: true,
  httpOnly: true,
});

const options = (
  await db
    .prepare(
      `SELECT id, option_datetime FROM poll_options WHERE poll_id = ? ORDER BY option_datetime ASC`
    )
    .bind(poll.id)
    .all<{ id: number; option_datetime: string }>()
).results;

const participants = (
  await db
    .prepare(
      `SELECT id, name FROM participants WHERE poll_id = ? ORDER BY created_at ASC`
    )
    .bind(poll.id)
    .all<{ id: number; name: string | null }>()
).results;

const allVotes = (
  await db
    .prepare(
      `SELECT v.participant_id, v.option_id, v.availability
       FROM votes v
       JOIN participants p ON p.id = v.participant_id
       WHERE p.poll_id = ?`
    )
    .bind(poll.id)
    .all<{ participant_id: number; option_id: number; availability: number }>()
).results;

// ── Pre-populate logged-in user's existing votes ──────────────────────────────

const currentUser = Astro.locals.user ?? null;
let myParticipantId: number | null = null;
const myVoteMap = new Map<number, number>(); // optionId → availability

// Invite token from ?invite= query param
const inviteToken = Astro.url.searchParams.get("invite") ?? null;
let inviteEmail: string | null = null;
let inviteHasVoted = false;

if (currentUser) {
  const myParticipant = await db
    .prepare(`SELECT id FROM participants WHERE poll_id = ? AND user_id = ?`)
    .bind(poll.id, currentUser.id)
    .first<{ id: number }>();

  if (myParticipant) {
    myParticipantId = myParticipant.id;
    const myVotes = (
      await db
        .prepare(`SELECT option_id, availability FROM votes WHERE participant_id = ?`)
        .bind(myParticipant.id)
        .all<{ option_id: number; availability: number }>()
    ).results;
    for (const v of myVotes) myVoteMap.set(v.option_id, v.availability);
  }
} else if (inviteToken) {
  const inviteParticipant = await db
    .prepare(`SELECT id, email FROM participants WHERE edit_token = ? AND poll_id = ?`)
    .bind(inviteToken, poll.id)
    .first<{ id: number; email: string | null }>();

  if (inviteParticipant) {
    myParticipantId = inviteParticipant.id;
    inviteEmail = inviteParticipant.email;
    const myVotes = (
      await db
        .prepare(`SELECT option_id, availability FROM votes WHERE participant_id = ?`)
        .bind(inviteParticipant.id)
        .all<{ option_id: number; availability: number }>()
    ).results;
    inviteHasVoted = myVotes.length > 0;
    for (const v of myVotes) myVoteMap.set(v.option_id, v.availability);
  }
}

// ── Poll state ────────────────────────────────────────────────────────────────

const isCreator = !!(currentUser && poll.creator_id && currentUser.id === poll.creator_id);
const isOpen = poll.chosen_option_id === null;

const chosenOption = poll.chosen_option_id
  ? await db
      .prepare(`SELECT id, option_datetime FROM poll_options WHERE id = ?`)
      .bind(poll.chosen_option_id)
      .first<{ id: number; option_datetime: string }>()
  : null;

// ── Build vote map for grid ───────────────────────────────────────────────────

// participantId → optionId → availability (0/1/2) | undefined = no response
const voteMap = new Map<number, Map<number, number>>();
for (const v of allVotes) {
  if (!voteMap.has(v.participant_id)) voteMap.set(v.participant_id, new Map());
  voteMap.get(v.participant_id)!.set(v.option_id, v.availability);
}

// Participants who have submitted at least one vote row
const respondedIds = new Set(allVotes.map((v) => v.participant_id));

// ── Option stats for the grid columns ────────────────────────────────────────

const optionStats = options.map((opt) => {
  let yesCount = 0;
  let maybeCount = 0;
  const yesNames: string[] = [];
  const maybeNames: string[] = [];

  for (const p of participants) {
    const av = voteMap.get(p.id)?.get(opt.id);
    if (av === 1) { yesCount++; yesNames.push(p.name ?? "Anonymous"); }
    else if (av === 2) { maybeCount++; maybeNames.push(p.name ?? "Anonymous"); }
  }

  return { ...opt, yesCount, maybeCount, score: yesCount * 2 + maybeCount, yesNames, maybeNames };
});

const maxScore = Math.max(0, ...optionStats.map((o) => o.score));

// ── Group options by calendar day for the vote form ──────────────────────────

type DayGroup = {
  dayName: string;    // "Monday"
  shortDate: string;  // "Apr 27"
  options: typeof options;
};

const dayGroups: DayGroup[] = [];
const dayKeyIndex = new Map<string, number>();

for (const opt of options) {
  const d = new Date(opt.option_datetime);
  const key = d.toISOString().slice(0, 10);
  if (!dayKeyIndex.has(key)) {
    dayKeyIndex.set(key, dayGroups.length);
    dayGroups.push({
      dayName: d.toLocaleDateString("en-US", { weekday: "long" }),
      shortDate: d.toLocaleDateString("en-US", { month: "short", day: "numeric" }),
      options: [],
    });
  }
  dayGroups[dayKeyIndex.get(key)!].options.push(opt);
}

// ── Helpers ───────────────────────────────────────────────────────────────────

function fmtTime(dt: string) {
  return new Date(dt).toLocaleTimeString("en-US", {
    hour: "numeric",
    minute: "2-digit",
    hour12: true,
  });
}

function fmtColDate(dt: string) {
  const d = new Date(dt);
  return {
    date: d.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" }),
    time: d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit", hour12: true }),
  };
}

function fmtFull(dt: string) {
  const d = new Date(dt);
  return d.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" })
    + " · "
    + d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit", hour12: true });
}

// Cell background for a given availability value
function cellBg(av: number | undefined): string {
  if (av === 1) return "background:var(--yes-bg)";
  if (av === 2) return "background:var(--maybe-bg)";
  if (av === 0) return "background:var(--busy-bg);opacity:0.6";
  return "";
}

function cellGlyph(av: number | undefined): string {
  if (av === 1) return "✓";
  if (av === 2) return "~";
  if (av === 0) return "✕";
  return "—";
}

function cellColor(av: number | undefined): string {
  if (av === 1) return "var(--yes)";
  if (av === 2) return "var(--maybe)";
  if (av === 0) return "var(--red)";
  return "var(--placeholder)";
}
---

<BaseLayout title={poll.title}>
  <!-- Poll header -->
  <div class="poll-header">
    <div class="absolute right-0 top-0 overflow-hidden h-full w-32 pointer-events-none" aria-hidden="true">
      <span class="ct-header-watermark">𝄴</span>
    </div>
    <div class="mx-auto max-w-5xl px-4 py-6 relative z-10">
      <p class="poll-eyebrow">♩ Poll</p>
      <h1 class="poll-title">{poll.title}</h1>
      {poll.description && (
        <p class="poll-desc">{poll.description}</p>
      )}
    </div>
  </div>

  <div class="mx-auto max-w-5xl px-4 py-8 space-y-10">

    <!-- ── Finalized banner / vote form ────────────────────────────────── -->
    {!isOpen ? (
      <div class="finalized-banner">
        <div class="finalized-banner-icon" aria-hidden="true">★</div>
        <div>
          <p class="finalized-eyebrow">Date confirmed</p>
          <p class="finalized-date">{chosenOption ? fmtFull(chosenOption.option_datetime) : ""}</p>
          <p class="finalized-sub">This poll is closed. Thanks to everyone who responded.</p>
          <a href={`/poll/${poll.token}/calendar.ics`} class="finalized-cal-link">Add to calendar →</a>
        </div>
      </div>
    ) : inviteToken && inviteHasVoted ? (
      <div class="invite-used-banner">
        <p class="invite-used-title">You've already responded</p>
        <p class="invite-used-sub">This invite link has been used. Your response is recorded — thanks!</p>
      </div>
    ) : (
      <div class="vote-card">
        <div class="vote-card-head">
          <h2 class="vote-card-title">Your availability</h2>
          <p class="vote-card-sub">
            {myParticipantId ? "Update your response below." : "Mark each time as yes, maybe, or busy."}
          </p>
        </div>

        {voteSuccess && (
          <div class="success-banner">
            <strong>Response saved!</strong>
            <span>Scroll down to see the updated availability.</span>
          </div>
        )}

        {voteError && (
          <div class="error-banner-inline">
            <strong>Couldn't save your response.</strong>
            {voteError.message && <span>{voteError.message}</span>}
          </div>
        )}

        {myParticipantId && (
          <div class="welcome-banner">
            <strong>Welcome back{currentUser?.email ? `, ${currentUser.email.split("@")[0]}` : ""}!</strong>
            <span>Your previous selections are loaded. Update any time.</span>
          </div>
        )}

        <form method="POST" action={actions.submitVote} id="vote-form">
          <input type="hidden" name="token" value={token} />
          <input type="hidden" name="voteData" id="vote-data" />
          {inviteToken && <input type="hidden" name="invite" value={inviteToken} />}

          <!-- Email row: read-only for invite, required for anonymous, hidden for logged-in -->
          {!currentUser && inviteEmail && (
            <div class="name-row">
              <label class="field-label">Your email</label>
              <p class="invite-email-display">{inviteEmail}</p>
            </div>
          )}
          {!currentUser && !inviteToken && (
            <div class="name-row">
              <label for="voter-email" class="field-label">Your email <span class="required-star">*</span></label>
              <input
                id="voter-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder="you@example.com"
                class="name-input"
              />
            </div>
          )}

          <!-- Name row -->
          <div class="name-row">
            <label for="voter-name" class="field-label">Your name</label>
            <input
              id="voter-name"
              name="name"
              type="text"
              autocomplete="name"
              value={currentUser?.email ?? ""}
              placeholder="e.g. Priya"
              class="name-input"
            />
          </div>

          <!-- Vibe legend -->
          <div class="vibe-legend">
            <div class="vibe-legend-item" style="background:var(--yes-bg)">
              <span style="color:var(--yes);font-weight:700;">✓</span>
              <span class="vibe-legend-label" style="color:var(--yes)">Yes</span>
            </div>
            <div class="vibe-legend-item" style="background:var(--maybe-bg)">
              <span style="color:var(--maybe);font-weight:700;">~</span>
              <span class="vibe-legend-label" style="color:var(--maybe)">Maybe</span>
            </div>
            <div class="vibe-legend-item" style="background:var(--busy-bg)">
              <span style="color:var(--red);font-weight:700;">✕</span>
              <span class="vibe-legend-label" style="color:var(--red)">Busy</span>
            </div>
          </div>

          <!-- Day groups -->
          {dayGroups.map((group) => (
            <div class="day-group">
              <div class="day-header">
                <span class="day-name">{group.dayName}</span>
                <span class="day-date">{group.shortDate}</span>
              </div>

              {group.options.map((opt) => {
                const existing = myVoteMap.get(opt.id);
                return (
                  <div
                    class="time-row"
                    data-option-id={opt.id}
                    data-init={existing ?? -1}
                  >
                    <div class="time-bullet" data-bullet></div>
                    <div class="time-label">{fmtTime(opt.option_datetime)}</div>
                    <div class="vibe-btns">
                      <button type="button" class="vibe-btn" data-vibe="1" title="Yes">✓</button>
                      <button type="button" class="vibe-btn" data-vibe="2" title="Maybe">~</button>
                      <button type="button" class="vibe-btn" data-vibe="0" title="Busy">✕</button>
                    </div>
                  </div>
                );
              })}
            </div>
          ))}

          <div class="vote-submit-row">
            <button type="submit" class="ct-btn">
              {myParticipantId ? "Update my response" : "Save my response"}
            </button>
          </div>
        </form>
      </div>
    )}

    <!-- ── Availability grid ──────────────────────────────────────────────── -->
    <div class="avail-section">
      <h2 class="avail-title">
        <span style="font-family:'Playfair Display',serif;color:var(--red);font-size:20px;margin-right:8px;" aria-hidden="true">𝄴</span>
        Availability
      </h2>

      {participants.length === 0 ? (
        <p class="avail-empty">No responses yet. Be the first!</p>
      ) : (
        <div class="avail-table-wrap">
          <table class="avail-table">
            <thead>
              <tr>
                <th class="avail-name-hdr">Who</th>
                {optionStats.map((opt) => {
                  const { date, time } = fmtColDate(opt.option_datetime);
                  const isChosen = opt.id === poll.chosen_option_id;
                  const isWinner = !isChosen && opt.score === maxScore && opt.score > 0;
                  return (
                    <th
                      class={`avail-opt-hdr${isChosen ? " chosen" : isWinner ? " winner" : ""}`}
                      title={[...opt.yesNames.map(n => `✓ ${n}`), ...opt.maybeNames.map(n => `~ ${n}`)].join("\n") || "No responses yet"}
                    >
                      <span class="avail-hdr-date">{date}</span>
                      <span class="avail-hdr-time">{time}</span>
                      <span class={`avail-hdr-count${isChosen ? " confirmed" : isWinner ? " hot" : ""}`}>
                        {opt.yesCount}/{respondedIds.size}
                        {isChosen ? " ★" : isWinner ? " ★" : ""}
                      </span>
                    </th>
                  );
                })}
              </tr>
            </thead>
            <tbody>
              {participants.map((p) => {
                const hasResponded = respondedIds.has(p.id);
                return (
                  <tr class={hasResponded ? "" : "pending-row"}>
                    <td class="avail-name-cell">
                      {p.name ?? <em class="anon">Anonymous</em>}
                      {!hasResponded && <span class="pending-badge">pending</span>}
                    </td>
                    {options.map((opt) => {
                      const av = voteMap.get(p.id)?.get(opt.id);
                      return (
                        <td class="avail-cell" style={cellBg(av)}>
                          <span style={`color:${cellColor(av)};font-weight:${av === 1 ? 700 : 400};font-size:${av === undefined ? "14px" : "17px"};`}>
                            {cellGlyph(av)}
                          </span>
                        </td>
                      );
                    })}
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}

      <!-- Grid legend -->
      {participants.length > 0 && (
        <div class="grid-legend">
          <span><strong style="color:var(--yes)">✓</strong> Yes</span>
          <span><strong style="color:var(--maybe)">~</strong> Maybe</span>
          <span><strong style="color:var(--red)">✕</strong> Busy</span>
          <span style="opacity:.55"><strong>—</strong> Pending</span>
        </div>
      )}
    </div>

    <!-- ── Invite section (creator only, while open) ────────────────────── -->
    {isCreator && isOpen && (
      <div class="invite-card">
        <div class="invite-card-head">
          <h2 class="invite-title">Invite people</h2>
          <p class="invite-sub">Send a direct link to this poll by email.</p>
        </div>

        {inviteResult?.data?.ok && (
          <div class="success-banner">
            <strong>Invites sent!</strong>
            <span>
              {inviteResult.data.count === 1
                ? "1 person invited."
                : `${inviteResult.data.count} people invited.`}
            </span>
          </div>
        )}

        {inviteError && (
          <div class="error-banner-inline">
            <strong>Couldn't send invites.</strong>
            {inviteError.message && <span>{inviteError.message}</span>}
          </div>
        )}

        <form method="POST" action={actions.inviteParticipants} class="invite-form">
          <input type="hidden" name="token" value={token} />
          <div class="invite-field">
            <label for="invite-emails" class="field-label">Email addresses</label>
            <textarea
              id="invite-emails"
              name="emails"
              placeholder={"alice@example.com, bob@example.com"}
              class="invite-textarea"
              rows={3}
            ></textarea>
            <p class="invite-hint">Separate multiple addresses with commas or new lines. Up to 20 per send.</p>
          </div>
          <div class="invite-submit-row">
            <button type="submit" class="invite-btn">♩ Send invites</button>
          </div>
        </form>
      </div>
    )}

    <!-- ── Finalize section (creator only, while open) ───────────────────── -->
    {isCreator && isOpen && (
      <div class="finalize-card">
        <div class="finalize-card-head">
          <h2 class="finalize-title">Finalize this poll</h2>
          <p class="finalize-sub">Choose a date to lock in and close this poll to new responses.</p>
        </div>

        {lockError && (
          <div class="error-banner-inline">
            <strong>Couldn't finalize.</strong>
            {lockError.message && <span>{lockError.message}</span>}
          </div>
        )}

        <form method="POST" action={actions.lockPoll} class="finalize-form">
          <input type="hidden" name="token" value={token} />

          <div class="finalize-options">
            {optionStats.map((opt, i) => {
              const isTop = opt.score === maxScore && opt.score > 0;
              return (
                <label class={`finalize-option${isTop ? " top" : ""}`}>
                  <input type="radio" name="optionId" value={opt.id} checked={i === 0} />
                  <span class="finalize-option-inner">
                    <span class="finalize-option-date">{fmtFull(opt.option_datetime)}</span>
                    <span class="finalize-option-votes">
                      <span style="color:var(--yes)">{opt.yesCount} yes</span>
                      {opt.maybeCount > 0 && <span style="color:var(--maybe)">{opt.maybeCount} maybe</span>}
                      {isTop && <span class="finalize-top-badge">★ top pick</span>}
                    </span>
                  </span>
                </label>
              );
            })}
          </div>

          <div class="finalize-submit-row">
            <button type="submit" class="ct-btn">
              ★ Lock in this date
            </button>
          </div>
        </form>
      </div>
    )}

  </div>
</BaseLayout>

<style>
  /* ── Poll header ────────────────────────────────────────────────────── */
  .poll-header {
    background: var(--ink);
    border-bottom: 3px solid var(--red);
    position: relative;
    overflow: hidden;
  }

  .ct-header-watermark {
    position: absolute;
    right: -8px;
    top: -20px;
    font-family: 'Playfair Display', serif;
    font-size: 140px;
    font-weight: 900;
    color: rgba(255,255,255,0.04);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .poll-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 8px;
  }

  .poll-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 5vw, 40px);
    font-weight: 900;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 6px;
  }

  .poll-desc {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--on-dark);
    margin-top: 6px;
  }

  /* ── Vote card ──────────────────────────────────────────────────────── */
  .vote-card {
    background: var(--white);
    border: 1px solid var(--staff);
    border-top: 3px solid var(--red);
  }

  .vote-card-head {
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--staff);
  }

  .vote-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
  }

  .vote-card-sub {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 15px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* Banners */
  .success-banner {
    padding: 14px 20px;
    background: var(--green-light);
    border-left: 3px solid var(--green);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .success-banner strong {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    color: var(--green);
  }

  .success-banner span {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 15px;
    color: var(--green);
  }

  .error-banner-inline {
    padding: 14px 20px;
    background: var(--busy-bg);
    border-left: 3px solid var(--red);
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: 'Libre Baskerville', serif;
    font-size: 16px;
    color: var(--ink);
  }

  .welcome-banner {
    padding: 14px 20px;
    background: var(--maybe-bg);
    border-left: 3px solid var(--maybe);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .welcome-banner strong {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--maybe-text);
  }

  .welcome-banner span {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 15px;
    color: var(--maybe-mid);
  }

  /* Name row */
  .name-row {
    padding: 14px 20px;
    border-bottom: 1px solid var(--staff);
  }

  .field-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .name-input {
    width: 100%;
    border: none;
    border-bottom: 2px solid var(--ink);
    background: transparent;
    font-family: 'Libre Baskerville', serif;
    font-size: 16px;
    color: var(--ink);
