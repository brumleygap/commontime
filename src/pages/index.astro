---
import BaseLayout from "../layouts/BaseLayout.astro";
import { env } from "cloudflare:workers";

const user = Astro.locals.user ?? null;

type PollRow = {
  token: string;
  title: string;
  created_at: string;
  is_creator: number;
  is_locked: number;
  is_open: number;
  participant_count: number;
  responded_count: number;
  // "YYYY-MM-DDTHH:MM|yesCount|maybeCount~..." one entry per option, sorted by datetime
  options_data: string | null;
  chosen_datetime: string | null;
};

type OptionData = { dt: string; yes: number; maybe: number };
type HeatDay    = { date: string; score: number; max: number };

type EnrichedPoll = PollRow & {
  heatDays: HeatDay[];
  chosenFormatted: string | null;
};

function parseOptions(raw: string | null): OptionData[] {
  if (!raw) return [];
  return raw.split("~").map(part => {
    const [dt, yes, maybe] = part.split("|");
    return { dt: dt ?? "", yes: parseInt(yes) || 0, maybe: parseInt(maybe) || 0 };
  });
}

function buildHeatDays(options: OptionData[], participantCount: number): HeatDay[] {
  const days = new Map<string, number>();
  for (const opt of options) {
    const date = opt.dt.slice(0, 10);
    const score = opt.yes * 2 + opt.maybe;
    if ((days.get(date) ?? -1) < score) days.set(date, score);
  }
  const max = participantCount * 2;
  return [...days.entries()].map(([date, score]) => ({ date, score, max }));
}

function cellColor(score: number, max: number): string {
  if (max === 0) return "#d4cfc6";
  const r = score / max;
  if (r >= 0.66) return "#166534";
  if (r >= 0.33) return "#4ade80";
  if (r >  0)    return "#d97706";
  return "#d4cfc6";
}

function fmtChosen(dt: string | null): string | null {
  if (!dt) return null;
  const d = new Date(dt);
  return (
    d.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" }) +
    " · " +
    d.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" })
  );
}

function enrich(p: PollRow): EnrichedPoll {
  return {
    ...p,
    heatDays: buildHeatDays(parseOptions(p.options_data), p.participant_count),
    chosenFormatted: fmtChosen(p.chosen_datetime),
  };
}

// Subquery fragments reused in both queries
const OPTIONS_DATA_SQL = `
  (SELECT GROUP_CONCAT(
      po.option_datetime || '|' ||
      CAST(COALESCE((SELECT COUNT(*) FROM votes WHERE option_id = po.id AND availability = 1), 0) AS TEXT) || '|' ||
      CAST(COALESCE((SELECT COUNT(*) FROM votes WHERE option_id = po.id AND availability = 2), 0) AS TEXT),
      '~'
    ) FROM poll_options po WHERE po.poll_id = p.id ORDER BY po.option_datetime
  ) AS options_data`;

const CHOSEN_DT_SQL = `
  (SELECT po.option_datetime FROM poll_options po WHERE po.id = p.chosen_option_id
  ) AS chosen_datetime`;

let myPolls: EnrichedPoll[] = [];
let guestPolls: EnrichedPoll[] = [];

if (user) {
  const { results } = await env.DB
    .prepare(
      `SELECT
         p.token, p.title, p.created_at,
         (p.creator_id = ?) AS is_creator,
         (p.chosen_option_id IS NOT NULL) AS is_locked,
         (p.chosen_option_id IS NULL AND (SELECT COUNT(*) FROM poll_options
          WHERE poll_id = p.id
            AND option_datetime > strftime('%Y-%m-%dT%H:%M', 'now')) > 0) AS is_open,
         (SELECT COUNT(*) FROM participants WHERE poll_id = p.id) AS participant_count,
         (SELECT COUNT(DISTINCT par.id)
          FROM participants par
          WHERE par.poll_id = p.id
            AND EXISTS(SELECT 1 FROM votes v WHERE v.participant_id = par.id)) AS responded_count,
         ${OPTIONS_DATA_SQL},
         ${CHOSEN_DT_SQL}
       FROM polls p
       WHERE (p.creator_id = ?
          OR p.id IN (SELECT poll_id FROM participants WHERE user_id = ?))
         AND p.token NOT IN (SELECT poll_token FROM poll_dismissals WHERE user_id = ?)
       ORDER BY p.created_at DESC
       LIMIT 20`
    )
    .bind(user.id, user.id, user.id, user.id)
    .all<PollRow>();
  myPolls = results.map(enrich);
} else {
  const guestCookie = Astro.cookies.get("recent_polls")?.value ?? "";
  const guestTokens = guestCookie ? guestCookie.split(",").filter(Boolean) : [];
  if (guestTokens.length > 0) {
    const placeholders = guestTokens.map(() => "?").join(",");
    const { results } = await env.DB
      .prepare(
        `SELECT
           p.token, p.title, p.created_at,
           0 AS is_creator,
           (p.chosen_option_id IS NOT NULL) AS is_locked,
           (p.chosen_option_id IS NULL AND (SELECT COUNT(*) FROM poll_options
            WHERE poll_id = p.id
              AND option_datetime > strftime('%Y-%m-%dT%H:%M', 'now')) > 0) AS is_open,
           (SELECT COUNT(*) FROM participants WHERE poll_id = p.id) AS participant_count,
           (SELECT COUNT(DISTINCT par.id)
            FROM participants par
            WHERE par.poll_id = p.id
              AND EXISTS(SELECT 1 FROM votes v WHERE v.participant_id = par.id)) AS responded_count,
           ${OPTIONS_DATA_SQL},
           ${CHOSEN_DT_SQL}
         FROM polls p
         WHERE p.token IN (${placeholders})
         ORDER BY p.created_at DESC`
      )
      .bind(...guestTokens)
      .all<PollRow>();
    guestPolls = results.map(enrich);
  }
}
---

<BaseLayout title="CommonTime">
  {user ? (
    <!-- ── Logged-in: poll dashboard ───────────────────────────── -->
    <div class="mx-auto max-w-2xl px-6 py-10">
      <div class="dash-header">
        <div>
          <p class="ct-eyebrow" style="margin-bottom: 2px;">Your polls</p>
          <p class="dash-sub">Polls you've created or responded to</p>
        </div>
        <a href="/create" class="new-poll-btn">♩ Create a poll</a>
      </div>

      {myPolls.length === 0 ? (
        <div class="empty-state">
          <span class="empty-glyph" aria-hidden="true">𝄴</span>
          <p class="empty-msg">No polls yet.</p>
          <a href="/create" class="ct-btn">♩ Create your first poll</a>
        </div>
      ) : (
        <div class="poll-list">
          {myPolls.map((poll) => (
            <div class="poll-card-wrap" data-token={poll.token}>
              <a href={`/poll/${poll.token}`} class={`poll-row${poll.is_creator ? " creator" : ""}`}>
                <div class="poll-row-body">
                  <span class="poll-row-title">{poll.title}</span>
                  <div class="poll-row-meta">
                    {poll.is_locked
                      ? <span class="status-badge locked">date set</span>
                      : poll.is_open
                        ? <span class="status-badge open">open</span>
                        : <span class="status-badge past">past</span>}
                    {poll.is_creator ? <span class="badge">Your Poll</span> : null}
                    <span>{poll.responded_count} / {poll.participant_count} responded</span>
                  </div>
                  {poll.is_locked
                    ? poll.chosenFormatted && (
                        <div class="poll-row-chosen">{poll.chosenFormatted}</div>
                      )
                    : poll.heatDays.length > 0 && (
                        <div class="poll-row-heat">
                          {poll.heatDays.slice(0, 14).map(day => (
                            <div class="heat-cell" style={`background:${cellColor(day.score, day.max)}`}></div>
                          ))}
                          {poll.heatDays.length > 14 && (
                            <span class="heat-more">+{poll.heatDays.length - 14}</span>
                          )}
                        </div>
                      )
                  }
                </div>
                <span class="poll-row-arrow" aria-hidden="true">→</span>
              </a>
              <button class="dismiss-btn" aria-label="Hide this poll" title="Hide">×</button>
            </div>
          ))}
        </div>
      )}
    </div>
  ) : guestPolls.length > 0 ? (
    <!-- ── Guest: polls they've participated in ───────────────── -->
    <div class="mx-auto max-w-2xl px-6 py-10">
      <div class="dash-header">
        <div>
          <p class="ct-eyebrow" style="margin-bottom: 2px;">Your polls</p>
          <p class="dash-sub">Polls you've been invited to</p>
        </div>
      </div>

      <div class="poll-list">
        {guestPolls.map((poll) => (
          <div class="poll-card-wrap" data-token={poll.token}>
            <a href={`/poll/${poll.token}`} class="poll-row">
              <div class="poll-row-body">
                <span class="poll-row-title">{poll.title}</span>
                <div class="poll-row-meta">
                  {poll.is_locked
                    ? <span class="status-badge locked">date set</span>
                    : poll.is_open
                      ? <span class="status-badge open">open</span>
                      : <span class="status-badge past">past</span>}
                  <span>{poll.responded_count} / {poll.participant_count} responded</span>
                </div>
                {poll.is_locked
                  ? poll.chosenFormatted && (
                      <div class="poll-row-chosen">{poll.chosenFormatted}</div>
                    )
                  : poll.heatDays.length > 0 && (
                      <div class="poll-row-heat">
                        {poll.heatDays.slice(0, 14).map(day => (
                          <div class="heat-cell" style={`background:${cellColor(day.score, day.max)}`}></div>
                        ))}
                        {poll.heatDays.length > 14 && (
                          <span class="heat-more">+{poll.heatDays.length - 14}</span>
                        )}
                      </div>
                    )
                }
              </div>
              <span class="poll-row-arrow" aria-hidden="true">→</span>
            </a>
            <button class="dismiss-btn" aria-label="Hide this poll" title="Hide">×</button>
          </div>
        ))}
      </div>

      <p class="guest-login-nudge">
        Want to create your own polls? <a href="/login">Log in →</a>
      </p>
    </div>
  ) : (
    <!-- ── Logged-out new visitor: marketing hero ─────────────── -->
    <section class="relative overflow-hidden" style="min-height: calc(100vh - 120px);">
      <div class="staff-bg absolute inset-0" aria-hidden="true"></div>
      <div class="time-sig" aria-hidden="true">4<br />4</div>

      <div class="relative z-10 mx-auto max-w-2xl px-6 py-24 text-center flex flex-col items-center">
        <div class="ct-watermark" aria-hidden="true">𝄴</div>
        <p class="ct-eyebrow mb-5">Schedule together</p>
        <h1 class="hero-headline">
          Find a time that<br /><em>works.</em>
        </h1>
        <p class="hero-sub">
          Pick dates. Share a link. See what works — all in common time.
        </p>
        <a href="/create" class="ct-btn" style="margin-bottom: 64px;">
          ♩ Create a Poll
        </a>
        <div class="note-row">
          <div class="note-item">
            <span class="note-glyph">♩</span>
            <span class="ct-eyebrow">Pick dates</span>
          </div>
          <div class="note-item">
            <span class="note-glyph">♪</span>
            <span class="ct-eyebrow">Share link</span>
          </div>
          <div class="note-item">
            <span class="note-glyph">♫</span>
            <span class="ct-eyebrow">Find time</span>
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ── Dashboard ───────────────────────────────────────────── */
  .dash-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 2px solid var(--ink);
  }

  .dash-sub {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    font-size: 15px;
    color: var(--muted);
    margin-top: 4px;
  }

  .new-poll-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--ink);
    padding: 10px 16px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: background 0.12s, color 0.12s;
    flex-shrink: 0;
  }

  .new-poll-btn:hover {
    background: var(--ink);
    color: var(--cream);
  }

  /* ── Poll list ───────────────────────────────────────────── */
  .poll-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .poll-card-wrap {
    position: relative;
  }

  .dismiss-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    border: none;
    background: none;
    color: var(--muted);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.1s, color 0.1s;
    z-index: 1;
  }

  .dismiss-btn:hover {
    background: var(--staff);
    color: var(--ink);
  }

  .poll-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 40px 16px 18px;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--staff);
    border-left: 3px solid var(--staff);
    background: #fff;
    box-shadow: 0 2px 6px rgba(15, 15, 14, 0.07), 0 1px 2px rgba(15, 15, 14, 0.04);
    transition: background 0.12s, box-shadow 0.12s, transform 0.12s;
  }

  .poll-row.creator {
    border-left-color: var(--red);
  }

  .poll-row:hover {
    background: var(--day-bg);
    box-shadow: 0 6px 16px rgba(15, 15, 14, 0.11), 0 2px 4px rgba(15, 15, 14, 0.06);
    transform: translateY(-1px);
  }

  .poll-row-body {
    flex: 1;
    min-width: 0;
  }

  .poll-row-title {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 5px;
  }

  .poll-row-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--muted);
    flex-wrap: wrap;
  }

  .badge {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1d4ed8;
    border: 1px solid #1d4ed8;
    padding: 2px 7px;
  }

  .status-badge {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 7px;
  }

  .status-badge.open {
    color: var(--yes);
    border: 1px solid var(--yes);
  }

  .status-badge.locked {
    color: var(--ink);
    border: 1px solid var(--ink);
  }

  .status-badge.past {
    color: var(--muted);
    border: 1px solid var(--staff);
  }

  .poll-row-arrow {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    color: var(--staff);
    flex-shrink: 0;
    transition: color 0.1s, transform 0.1s;
  }

  .poll-row:hover .poll-row-arrow {
    color: var(--ink);
    transform: translateX(2px);
  }

  /* ── Heatmap ─────────────────────────────────────────────── */
  .poll-row-heat {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 3px;
    margin-top: 8px;
  }

  .heat-cell {
    width: 8px;
    height: 16px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .heat-more {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  /* ── Chosen date (locked polls) ──────────────────────────── */
  .poll-row-chosen {
    margin-top: 7px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--ink);
  }

  /* ── Empty state ─────────────────────────────────────────── */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 60px 24px;
    text-align: center;
    border: 1px solid var(--staff);
    background: var(--white);
  }

  .empty-glyph {
    font-family: 'Playfair Display', serif;
    font-size: 64px;
    font-weight: 900;
    color: var(--ink);
    opacity: 0.08;
    line-height: 1;
  }

  .empty-msg {
    font-family: 'Libre Baskerville', serif;
    font-style: italic;
    color: var(--muted);
    font-size: 17px;
    margin-top: -8px;
  }

  /* ── Hero (logged-out) ───────────────────────────────────── */
  .time-sig {
    position: absolute;
    right: 6%;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    color: var(--ink);
    opacity: 0.05;
    line-height: 0.85;
    font-size: clamp(72px, 12vw, 140px);
    text-align: center;
    user-select: none;
    pointer-events: none;
  }

  .ct-watermark {
    font-size: clamp(120px, 22vw, 220px);
    line-height: 1;
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    color: var(--ink);
    opacity: 0.05;
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    letter-spacing: -10px;
    user-select: none;
    pointer-events: none;
  }

  .hero-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(44px, 9vw, 80px);
    font-weight: 900;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 20px;
    position: relative;
  }

  .hero-headline em {
    color: var(--red);
    font-style: italic;
  }

  .hero-sub {
    font-family: 'Libre Baskerville', serif;
    font-size: 18px;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 44px;
    max-width: 380px;
  }

  .note-row {
    display: flex;
    justify-content: center;
    gap: 44px;
  }

  .note-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .note-glyph {
    font-size: 32px;
    opacity: 0.2;
    color: var(--ink);
    line-height: 1;
  }

  /* ── Guest login nudge ───────────────────────────────────── */
  .guest-login-nudge {
    margin-top: 20px;
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-align: center;
  }

  .guest-login-nudge a {
    color: var(--ink);
    text-underline-offset: 2px;
  }

  /* ── Mobile layout ──────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .dash-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }

    .new-poll-btn {
      width: 100%;
      justify-content: center;
    }

    .poll-row {
      padding: 14px 14px;
    }

    .poll-row-title {
      font-size: 17px;
    }

    .poll-row-meta {
      gap: 8px;
    }
  }
</style>

<script>
  // localStorage: immediate feedback while page is open (guest fallback)
  const STORAGE_KEY = "ct_hidden_polls";

  function getHidden(): Set<string> {
    try {
      return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]"));
    } catch {
      return new Set();
    }
  }

  function saveHiddenLocal(token: string) {
    const hidden = getHidden();
    hidden.add(token);
    localStorage.setItem(STORAGE_KEY, JSON.stringify([...hidden]));
  }

  // Server-side persistence for logged-in users
  function saveDismissalToServer(token: string) {
    fetch("/api/polls/dismiss", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ token }),
    }).catch(() => {}); // fire-and-forget; localStorage is the fallback
  }

  function applyHidden() {
    const hidden = getHidden();
    document.querySelectorAll<HTMLElement>(".poll-card-wrap[data-token]").forEach((el) => {
      if (hidden.has(el.dataset.token!)) el.style.display = "none";
    });
  }

  function dismissCard(wrap: HTMLElement) {
    const token = wrap.dataset.token!;
    saveHiddenLocal(token);
    saveDismissalToServer(token);
    // Animate out, then hide
    wrap.style.transition = "opacity 0.2s, transform 0.25s, max-height 0.3s, margin 0.3s";
    wrap.style.overflow = "hidden";
    wrap.style.maxHeight = wrap.offsetHeight + "px";
    requestAnimationFrame(() => {
      wrap.style.opacity = "0";
      wrap.style.transform = "translateX(40px)";
      wrap.style.maxHeight = "0";
      wrap.style.marginBottom = "0";
    });
    setTimeout(() => { wrap.style.display = "none"; }, 320);
  }

  applyHidden();
  // Re-apply on bfcache restore (tap-back on mobile)
  window.addEventListener("pageshow", applyHidden);

  document.querySelectorAll<HTMLButtonElement>(".dismiss-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      const wrap = btn.closest<HTMLElement>(".poll-card-wrap");
      if (wrap) dismissCard(wrap);
    });
  });
</script>
